{
  "name": "@cobweb/server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "cobweb backend (Bun + Hono RPC)",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
